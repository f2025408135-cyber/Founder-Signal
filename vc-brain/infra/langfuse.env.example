# Langfuse env example — copy to .env and adjust
# Self-hosted Langfuse v3

DATABASE_URL=postgresql://vcbrain:vcbrain@localhost:5432/vcbrain
NEXTAUTH_SECRET=change-me-to-a-long-random-string
SALT=change-me-to-another-long-random-string
NEXTAUTH_URL=http://localhost:3000

# Public/Langfuse SDK credentials (create a project in the UI to get these)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000
