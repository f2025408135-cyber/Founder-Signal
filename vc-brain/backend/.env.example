# VC Brain backend .env — copy to .env and fill in real values

# Postgres (matches infra/docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://vcbrain:vcbrain@localhost:5432/vcbrain
DATABASE_SYNC_URL=postgresql://vcbrain:vcbrain@localhost:5432/vcbrain

# OpenAI — GPT-5.6 series per spec §1
OPENAI_API_KEY=sk-...
WORKER_MODEL=gpt-5.6-luna
SYNTHESIZER_MODEL=gpt-5.6-sol

# Langfuse
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# External ingestion APIs
GITHUB_TOKEN=ghp_...
PRODUCTHUNT_TOKEN=...

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# Rescore cache
RESCORE_CACHE_TTL_MINUTES=60
STALE_CACHE_HOURS=24
